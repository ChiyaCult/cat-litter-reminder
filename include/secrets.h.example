// Copy this file to secrets.h (in this same include/ folder) and fill in
// your real credentials. secrets.h is gitignored -- never commit your
// actual credentials.
#pragma once

#define WIFI_SSID "your-wifi-name"
#define WIFI_PASSWORD "your-wifi-password"

// MQTT broker for Home Assistant integration (see ADR-0003).
// MQTT_HOST: hostname or IP of your broker, e.g. "homeassistant.local"
// MQTT_PORT: typically 1883 (unencrypted)
// The broker is expected to allow anonymous connections.
#define MQTT_HOST "your-mqtt-broker-host"
#define MQTT_PORT 1883
